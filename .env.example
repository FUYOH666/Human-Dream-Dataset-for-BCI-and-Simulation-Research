# Telegram Bot (required)
TELEGRAM_BOT_TOKEN=your_bot_token

# ASR service (port 8001, e.g. Whisper)
LOCAL_AI_ASR_BASE_URL=http://your-asr-host:8001
LOCAL_AI_ASR_TIMEOUT=600

# LLM service (port 8005, OpenAI-compatible)
LOCAL_AI_LLM_BASE_URL=http://your-llm-host:8005
LOCAL_AI_LLM_TIMEOUT=180

# Optional: OpenRouter for cloud LLM
# OPENROUTER_API_KEY=sk-or-...
# OPENROUTER_MODEL=openai/gpt-4o-mini
# USE_OPENROUTER=false

# Optional: Qdrant + Embedding + Reranker for interpretation experiment
# QDRANT_URL=http://your-host:6333
# LOCAL_AI_EMBEDDING_BASE_URL=http://your-embedding-host:9001
# LOCAL_AI_RERANKER_BASE_URL=http://your-reranker-host:9002
